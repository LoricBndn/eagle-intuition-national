generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
}

model Newsletter {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Image {
  id                  String          @id @default(uuid())
  url                 String
  postId              String?
  post                Post?           @relation(fields: [postId], references: [id])
  courseIcon          Course?         @relation("CourseIcon")
  erasmusCourseImage  ErasmusCourse?  @relation("ErasmusCourseImage")
  erasmusProjectImage ErasmusProject? @relation("ErasmusProjectImage")
}

model Course {
  id          String   @id @default(uuid())
  title       String
  description String
  active      Boolean
  date        DateTime @default(now())
  iconId      String   @unique
  icon        Image    @relation("CourseIcon", fields: [iconId], references: [id])
}

model ErasmusCourse {
  id          String   @id @default(uuid())
  title       String
  description String
  content     String
  date        DateTime @default(now())
  imageId     String   @unique
  image       Image    @relation("ErasmusCourseImage", fields: [imageId], references: [id])
}

model ErasmusProject {
  id      String   @id @default(uuid())
  title   String
  url     String
  date    DateTime @default(now())
  imageId String   @unique
  image   Image    @relation("ErasmusProjectImage", fields: [imageId], references: [id])
}

enum Category {
  Web
  Facebook
}

model Post {
  id       String   @id @default(uuid())
  title    String
  category Category
  content  String
  date     DateTime @default(now())
  images   Image[]
}

model Video {
  id    String   @id @default(uuid())
  title String
  url   String
  date  DateTime @default(now())
}
