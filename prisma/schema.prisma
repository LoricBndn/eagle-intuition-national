generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
}

model Newsletter {
  id        String             @id @default(uuid())
  email     String             @unique
  createdAt DateTime           @default(now())
  category  CategoryNewsletter
}

model Course {
  id        String   @id @default(uuid())
  title     String
  createdAt DateTime @default(now())
  iconUrl   String   @unique
}

model Post {
  id        String       @id @default(uuid())
  slug      String       @unique
  title     String
  category  CategoryPost
  content   String
  createdAt DateTime     @default(now())
  imagesUrl String[]
  url       String
}

model ErasmusCourse {
  id          String   @id @default(uuid())
  title       String
  description String
  content     String
  createdAt   DateTime @default(now())
  imageUrl    String   @unique
}

model ErasmusProject {
  id        String   @id @default(uuid())
  title     String
  url       String
  createdAt DateTime @default(now())
  imageUrl  String   @unique
}

model Video {
  id        String   @id @default(uuid())
  title     String
  url       String
  createdAt DateTime @default(now())
}

enum CategoryPost {
  Web
  Facebook
}

enum CategoryNewsletter {
  National
  International
}
